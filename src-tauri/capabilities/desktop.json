{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "desktop-capability",
    "windows": ["main"],
    "platforms": ["linux"],
    "permissions": [
        "clipboard-manager:allow-write-text",
        "core:path:default",
        "core:event:default",
        "core:window:default",
        "core:app:default", 
        "core:resources:default",
        "core:menu:default",
        "core:tray:default",
        "core:window:allow-set-title"
    ]
  }
  